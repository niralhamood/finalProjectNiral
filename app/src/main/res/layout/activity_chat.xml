<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".ChatActivity">

    <!-- عنوان الشاشة -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Chat with Ai"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#3F51B5"
        android:layout_marginBottom="16dp"
        android:gravity="center" />

    <!-- حقل إدخال الطالب -->
    <EditText
        android:id="@+id/etTaskTopic"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="بماذا تفكر؟ (مثلاً: أريد تنظيم وقتي أو أحتاج لتشجيع)"
        android:minHeight="48dp"
        android:padding="12dp"
        android:background="@android:drawable/edit_text" />

    <!-- زر طلب المساعدة من الذكاء الاصطناعي -->
    <Button
        android:id="@+id/btnSuggestSteps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:backgroundTint="#3F51B5"
        android:text="الحصول على إرشاد / دعم"
        android:textColor="#FFFFFF" />

    <!-- مؤشر التحميل -->
    <ProgressBar
        android:id="@+id/pbLoading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="16dp"
        android:visibility="gone" />

    <!-- منطقة عرض رد الذكاء الاصطناعي -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp"
        android:background="#F5F5F5"
        android:padding="8dp">

        <TextView
            android:id="@+id/tvAiResponse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="#333333"
            android:lineSpacingExtra="4dp"
            android:textIsSelectable="true" />
    </ScrollView>
</LinearLayout>


