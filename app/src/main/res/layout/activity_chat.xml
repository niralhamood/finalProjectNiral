<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FFF0F5"
    tools:context=".ChatActivity">

    <!-- Screen Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Focus Up AI Chat"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#E91E63"
        android:layout_marginBottom="20dp"
        android:gravity="center" />

    <!-- User Input -->
    <EditText
        android:id="@+id/etTaskTopic"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="What are you thinking about?"
        android:minHeight="50dp"
        android:padding="12dp"
        android:textColor="#880E4F"
        android:textColorHint="#C2185B"
        android:backgroundTint="#F48FB1" />

    <!-- AI Support Button -->
    <Button
        android:id="@+id/btnSuggestSteps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:backgroundTint="#EC407A"
        android:text="Get Support"
        android:textStyle="bold"
        android:textColor="#FFFFFF" />

    <!-- Loading Indicator -->
    <ProgressBar
        android:id="@+id/pbLoading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="16dp"
        android:indeterminateTint="#E91E63"
        android:visibility="gone" />

    <!-- AI Response Area -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="18dp"
        android:background="#FCE4EC"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvAiResponse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="#880E4F"
            android:lineSpacingExtra="5dp"
            android:textIsSelectable="true" />
    </ScrollView>

</LinearLayout>