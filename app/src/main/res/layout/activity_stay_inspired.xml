<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7EFEF"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="City Inspired"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#333"
            android:layout_marginTop="20dp"/>

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="A Boost of\nMotivation, Delivered."
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#000"
            android:gravity="center"
            android:layout_marginTop="16dp"/>

        <!-- Description -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Activating this mode will send periodic uplifting messages to help you stay positive throughout your day."
            android:textSize="14sp"
            android:textColor="#666"
            android:gravity="center"
            android:layout_marginTop="12dp"/>

        <!-- Section Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choose Message Mode"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#000"
            android:layout_marginTop="30dp"/>

        <!-- Radio Group -->
        <RadioGroup
            android:id="@+id/modeRadioGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <RadioButton
                android:id="@+id/rbMotivational"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Motivational"
                android:textSize="14sp"
                android:layout_marginBottom="10dp"/>

            <RadioButton
                android:id="@+id/rbGuiltDriven"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Guilt Drive"
                android:textSize="14sp"/>
        </RadioGroup>

        <!-- Start Button -->
        <Button
            android:id="@+id/btnStart"
            android:layout_width="200dp"
            android:layout_height="50dp"
            android:text="Start"
            android:textAllCaps="false"
            android:layout_marginTop="30dp"
            android:backgroundTint="#FFE0E0"
            android:textColor="#000"
            android:background="@drawable/rounded_button2"/>

        <!-- Status -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status: Inactive"
            android:textSize="13sp"
            android:textColor="#777"
            android:layout_marginTop="16dp"/>

    </LinearLayout>

</ScrollView>