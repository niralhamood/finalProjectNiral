<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFF8F8"
    android:padding="20dp">

    <!-- نص الترحيب -->
    <TextView
        android:id="@+id/greetingText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Good Morning, User"
        android:textStyle="bold"
        android:textSize="22sp"
        android:textColor="#1E1E1E"
        android:paddingBottom="6dp"/>

    <TextView
        android:id="@+id/subGreetingText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Let's make today productive!"
        android:textSize="14sp"
        android:textColor="#666666"
        android:paddingBottom="20dp"/>

    <!-- زر المهام أو الإلهام -->
    <Button
        android:id="@+id/btnTasks"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📘  My Tasks"
        android:textSize="16sp"
        android:backgroundTint="#FFE0E0"
        android:textColor="#000"
        android:layout_marginBottom="12dp"/>

    <!-- الزر الجديد: Stay Inspired -->
    <Button
        android:id="@+id/btnStayInspired"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="💡  Stay Inspired"
        android:textSize="16sp"
        android:backgroundTint="#FFE0E0"
        android:textColor="#000"
        android:layout_marginBottom="12dp"/>

    <!-- مساحة فارغة قبل الشريط السفلي -->

    <!-- شريط تنقل سفلي بسيط -->

    <Button
        android:id="@+id/btnChat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:backgroundTint="#FFE0E0"
        android:text="💬  Chat with AI"
        android:textColor="#000"
        android:textSize="16sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
